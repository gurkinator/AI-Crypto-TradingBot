# Copy this file to .env and fill in your own values.
# Never upload .env to GitHub.

KUCOIN_API_KEY=
KUCOIN_SECRET=
KUCOIN_PASSPHRASE=

# Also accepted by bot.py:
# KUCOIN_API_SECRET=
# KUCOIN_API_PASSWORD=
# KUCOIN_PASSWORD=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

