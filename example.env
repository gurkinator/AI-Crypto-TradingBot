BOT_UI_RESERVED_CORES=4
BOT_OPT_MAX_WORKERS=
BOT_OPT_WORKERS_FORCE=0

# Optional emergency/dev toggles
# BOT_DISABLE_LOGIN=1
# BOT_DISABLE_AUTORUN=1
